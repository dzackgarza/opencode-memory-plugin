source_up
dotenv_if_exists .env

export OPENCODE_CONFIG="$PWD/.config/opencode.json"
export OPENCODE_CONFIG_DIR="$PWD/.config"
export POSTGRES_MEMORY_TEST_PASSPHRASE="PGMEM-VECTOR-42"

# Required in .env for live Postgres verification:
# POSTGRES_MEMORY_TEST_ADMIN_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
# POSTGRES_MEMORY_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/opencode-memories
